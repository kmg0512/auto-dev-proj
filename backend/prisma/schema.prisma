generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  streak    Int      @default(0)
  level     Int      @default(1)
  exp       Int      @default(0)
  guildId   String?
  guild     Guild?   @relation(fields: [guildId], references: [id])
  habits    Habit[]
  quests    Quest[]
  inventory Inventory[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Habit {
  id          String   @id @default(uuid())
  title       String
  description String?
  frequency   String   @default("daily")
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Guild {
  id        String            @id @default(uuid())
  name      String            @unique
  bossHp    Int               @default(10000)
  members   User[]
  invites   GuildInvitation[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model GuildInvitation {
  id        String           @id @default(uuid())
  guildId   String
  guild     Guild            @relation(fields: [guildId], references: [id])
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([guildId, userId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Quest {
  id          String   @id @default(uuid())
  title       String
  description String?
  isCompleted Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inventory {
  id        String   @id @default(uuid())
  itemName  String
  quantity  Int      @default(1)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
